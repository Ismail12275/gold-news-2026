# ─────────────────────────────────────────────────────────────────────────────
#  XAUUSD/USD Macro Bot — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID where alerts will be sent
# To get your chat ID: message @userinfobot or @RawDataBot
# Multiple chats: separate by comma  e.g.  -1001234567890,-987654321
TELEGRAM_CHAT_ID=your_chat_id_here

# ── AI KEYS (at least one recommended) ───────────────────────────────────────

# Anthropic Claude API key (primary AI analyzer)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (fallback analyzer — optional)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── OPTIONAL NEWS SOURCE ─────────────────────────────────────────────────────

# NewsAPI key — adds +30 articles per cycle from premium sources
# Free plan: 100 req/day   https://newsapi.org/
NEWSAPI_KEY=

# ── BOT BEHAVIOUR ─────────────────────────────────────────────────────────────

# Polling interval in seconds (default: 600 = 10 minutes)
POLL_INTERVAL=600

# Maximum messages sent per hour (default: 5)
MAX_MSG_PER_HOUR=5

# Path to deduplication storage file (default: storage.json)
STORAGE_PATH=storage.json

# How many days to keep fingerprints in storage (default: 7)
DEDUP_RETENTION_DAYS=7
