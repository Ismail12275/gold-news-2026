# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── AI Providers (set at least GEMINI_API_KEY) ─────────────
# PRIMARY — free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# FALLBACK 1 — free tier at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# FALLBACK 2 — https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# ─── Optional: Finnhub for extra news ───────────────────────
FINNHUB_API_KEY=your_finnhub_key_here

# ─── Bot behavior ───────────────────────────────────────────
POLL_INTERVAL=300
MIN_MACRO_SCORE=2
MIN_PRIORITY=1
MAX_ALERTS_PER_CYCLE=5
SEND_NON_TRADABLE=false

# ─── Deduplication ──────────────────────────────────────────
DEDUP_FILE=seen_news.json
DEDUP_TTL_HOURS=24
