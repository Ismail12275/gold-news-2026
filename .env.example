# ─────────────────────────────────────────────────────────────────────────────
#  XAUUSD/USD Macro Bot — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID where alerts will be sent
# To get your chat ID: message @userinfobot or @RawDataBot
# Multiple chats: separate by comma  e.g.  -1001234567890,-987654321
TELEGRAM_CHAT_ID=your_chat_id_here

# ── AI ANALYSIS — FREE ONLY (no paid APIs) ──────────────────────────────────

# Option A (preferred): Google Gemini free tier
# - Free tier: 15 req/min, 1,500 req/day — no credit card needed
# - Get key:   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — gemini-1.5-flash is fastest and free
GEMINI_MODEL=gemini-1.5-flash

# Option B (fallback): Ollama — local LLM, fully offline, zero cost
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull:    ollama pull gemma2
# Start:   ollama serve
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2

# ── OPTIONAL NEWS SOURCE ─────────────────────────────────────────────────────

# NewsAPI key — adds +30 articles per cycle from premium sources
# Free plan: 100 req/day   https://newsapi.org/
NEWSAPI_KEY=

# ── BOT BEHAVIOUR ─────────────────────────────────────────────────────────────

# Polling interval in seconds (default: 600 = 10 minutes)
POLL_INTERVAL=600

# Maximum messages sent per hour (default: 5)
MAX_MSG_PER_HOUR=5

# Path to deduplication storage file (default: storage.json)
STORAGE_PATH=storage.json

# How many days to keep fingerprints in storage (default: 7)
DEDUP_RETENTION_DAYS=7
